{
  "info": {
    "name": "MENUL API Collection",
    "description": "Postman collection aligned with current MENUL backend routes (Django DRF).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Keep base URL easy to change per environment.",
          "if (!pm.collectionVariables.get('base_url')) pm.collectionVariables.set('base_url', 'http://127.0.0.1:8000');"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "{{base_protocol}}://{{base_host}}:{{base_port}}"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "user_id",
      "value": "1"
    },
    {
      "key": "restaurant_id",
      "value": "1"
    },
    {
      "key": "branch_id",
      "value": "1"
    },
    {
      "key": "table_id",
      "value": "1"
    },
    {
      "key": "kitchen_id",
      "value": "1"
    },
    {
      "key": "category_id",
      "value": "1"
    },
    {
      "key": "item_id",
      "value": "1"
    },
    {
      "key": "session_id",
      "value": "00000000-0000-0000-0000-000000000000"
    },
    {
      "key": "order_item_id",
      "value": "1"
    },
    {
      "key": "uidb64",
      "value": ""
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "base_protocol",
      "value": "http"
    },
    {
      "key": "base_host",
      "value": "127.0.0.1"
    },
    {
      "key": "base_port",
      "value": "8000"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/register/",
              "protocol": "{{base_protocol}}",
              "host": [
                "{{base_host}}"
              ],
              "port": "{{base_port}}",
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"owner_demo\",\n  \"email\": \"owner@example.com\",\n  \"password\": \"StrongPass123!\"\n}"
            },
            "auth": {
              "type": "noauth"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.access) pm.collectionVariables.set('access_token', data.access);",
                  "if (data.refresh) pm.collectionVariables.set('refresh_token', data.refresh);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
